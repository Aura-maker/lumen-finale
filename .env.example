# 🤖 CONFIGURAZIONE AI SERVICES
# Copia questo file in .env e inserisci le tue API keys

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview
AI_PROVIDER=openai

# Anthropic Configuration (opzionale)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-opus-20240229

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/imparafacile

# App Configuration
APP_URL=http://localhost:4000
NODE_ENV=development
PORT=4000

# Per usare OpenAI:
# 1. Vai su https://platform.openai.com/api-keys
# 2. Crea una nuova API key
# 3. Sostituisci "your_openai_api_key_here" con la tua chiave
# 4. Riavvia il server
